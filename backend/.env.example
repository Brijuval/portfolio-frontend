EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
CONTACT_RECEIVER_EMAIL=your-email@gmail.com
